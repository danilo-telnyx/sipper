# Database Configuration
# Generate a secure password: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DB_USER=sipper
DB_PASSWORD=change_this_password_in_production
DB_NAME=sipper_db

# Backend API Configuration
DATABASE_URL=postgresql+asyncpg://sipper:change_this_password_in_production@db:5432/sipper_db

# Security Secrets (MUST be changed in production!)
# Generate JWT_SECRET (48 chars): python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_this_to_a_random_string_min_32_characters_long

# Generate ENCRYPTION_KEY (Fernet key): python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_this_to_another_random_32_char_string

# API Server
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=production

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
