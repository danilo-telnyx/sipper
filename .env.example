# SIPPER Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_NAME=sipper
DB_USER=sipper
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_ENV=production
APP_PORT=8000
LOG_LEVEL=info
SECRET_KEY=your_secret_key_here_min_32_chars

# =============================================================================
# SIP CONFIGURATION
# =============================================================================
# Target SIP server for testing
SIP_SERVER=sip.example.com
SIP_PORT=5060
SIP_TRANSPORT=UDP

# SIP user credentials (for registration tests)
SIP_USERNAME=testuser
SIP_PASSWORD=testpassword
SIP_DOMAIN=example.com

# =============================================================================
# TELNYX INTEGRATION (Optional)
# =============================================================================
# Leave empty if not using Telnyx
TELNYX_API_KEY=
TELNYX_SIP_CONNECTION_ID=

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Default test parameters
TEST_TIMEOUT=30
TEST_RETRY_COUNT=3
CONCURRENT_CALLS_LIMIT=10

# =============================================================================
# SECURITY
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT token expiration (minutes)
JWT_EXPIRATION=60

# =============================================================================
# MONITORING (Optional)
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
